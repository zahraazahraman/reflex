<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.ChasePage"
             BackgroundColor="#050508"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="40,32,40,0" Spacing="4">
            <Label Text="Test 4 of 5  ·  Chase"
                   FontSize="12"
                   TextColor="#444455"
                   HorizontalOptions="Center" />
            <Label Text="Follow the dot. Hold steady."
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"
                   HorizontalOptions="Center"
                   Margin="0,6,0,0" />
        </VerticalStackLayout>

        <!-- Chase canvas + overlaid countdown -->
        <Grid Grid.Row="1">
            <GraphicsView x:Name="ChaseView"
                          BackgroundColor="#050508">
                <GraphicsView.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPanUpdated" />
                </GraphicsView.GestureRecognizers>
            </GraphicsView>

            <!-- Countdown — sits top-centre over the canvas -->
            <Label x:Name="TimerLabel"
                   Text="30"
                   FontSize="48"
                   FontAttributes="Bold"
                   TextColor="#1A3A4A"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="0,16,0,0"
                   InputTransparent="True" />
        </Grid>

        <!-- Cancel / Skip -->
        <Grid Grid.Row="2" Padding="40,0,40,40" ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#1A1A2E"
                    TextColor="#555566"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="2"
                    Text="Skip →"
                    BackgroundColor="#1A1A2E"
                    TextColor="#333355"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnSkipClicked" />
        </Grid>

    </Grid>

</ContentPage>
