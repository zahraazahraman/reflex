<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.PulsePage"
             BackgroundColor="#0A0A12"
             Shell.NavBarIsVisible="False">

    <Grid Padding="40" RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Test 5 of 5  ·  Pulse"
                   FontSize="12"
                   TextColor="#444455"
                   HorizontalOptions="Center" />
            <Label Text="Finger on the lens."
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"
                   HorizontalOptions="Center"
                   Margin="0,8,0,0" />
            <Label Text="Place your index finger over the rear camera. Breathe normally."
                   FontSize="13"
                   TextColor="#888899"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Central readout -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="18">

            <!-- Pulsing heart circle -->
            <Frame x:Name="HeartCircle"
                   BackgroundColor="#1A0A0A"
                   BorderColor="#3A1A1A"
                   CornerRadius="80"
                   WidthRequest="160"
                   HeightRequest="160"
                   HorizontalOptions="Center"
                   Padding="0">
                <Label Text="♥"
                       FontSize="56"
                       TextColor="#FF3D3D"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>

            <!-- Status line: "Detecting…" / "Measuring" -->
            <Label x:Name="StatusLabel"
                   Text="Detecting…"
                   FontSize="13"
                   TextColor="#555566"
                   HorizontalOptions="Center" />

            <!-- Live BPM -->
            <Label x:Name="BpmLabel"
                   Text="-- BPM"
                   FontSize="40"
                   FontAttributes="Bold"
                   TextColor="#FF6B6B"
                   HorizontalOptions="Center" />

            <!-- HRV -->
            <Label x:Name="HrvLabel"
                   Text="HRV: -- ms"
                   FontSize="14"
                   TextColor="#555566"
                   HorizontalOptions="Center" />

            <!-- Countdown -->
            <Label x:Name="TimerLabel"
                   Text="30"
                   FontSize="22"
                   TextColor="#00E5FF"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>

        <!-- Cancel / Next (Skip) -->
        <Grid Grid.Row="2" ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#1A1A2E"
                    TextColor="#555566"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="2"
                    Text="Skip →"
                    BackgroundColor="#1A1A2E"
                    TextColor="#333355"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnSkipClicked" />
        </Grid>

    </Grid>

</ContentPage>
