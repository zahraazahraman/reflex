<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.StrikePage"
             BackgroundColor="#050508"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="40,32,40,0" Spacing="4">
            <Label Text="Test 2 of 5  ·  Strike"
                   FontSize="12"
                   TextColor="#444455"
                   HorizontalOptions="Center" />
            <Label x:Name="TrialLabel"
                   Text="Get ready…"
                   FontSize="16"
                   TextColor="#555566"
                   HorizontalOptions="Center"
                   Margin="0,8,0,0" />
        </VerticalStackLayout>

        <!-- Random-position tap target -->
        <AbsoluteLayout x:Name="TargetArea" Grid.Row="1">
            <Frame x:Name="StrikeTarget"
                   IsVisible="False"
                   BackgroundColor="#00FF88"
                   WidthRequest="80"
                   HeightRequest="80"
                   CornerRadius="40"
                   HasShadow="False"
                   Padding="0"
                   BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTargetTapped" />
                </Frame.GestureRecognizers>
            </Frame>
        </AbsoluteLayout>

        <!-- Cancel / Skip (skip for dev use) -->
        <Grid Grid.Row="2" Padding="40,0,40,40" ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#1A1A2E"
                    TextColor="#555566"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="2"
                    Text="Skip →"
                    BackgroundColor="#1A1A2E"
                    TextColor="#333355"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnSkipClicked" />
        </Grid>

    </Grid>

</ContentPage>
