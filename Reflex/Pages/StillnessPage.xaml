<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.StillnessPage"
             BackgroundColor="#0A0A12"
             Shell.NavBarIsVisible="False">

    <Grid Padding="40" RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Test 1 of 5  ·  Stillness"
                   FontSize="12"
                   TextColor="#444455"
                   HorizontalOptions="Center" />
            <Label Text="Hold still."
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"
                   HorizontalOptions="Center"
                   Margin="0,8,0,0" />
            <Label Text="Phone flat on your open palm. Eyes closed."
                   FontSize="14"
                   TextColor="#888899"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Live waveform canvas -->
        <GraphicsView x:Name="WaveformView"
                      Grid.Row="1"
                      Margin="0,24"
                      BackgroundColor="#0D0D1A" />

        <!-- Countdown timer -->
        <Label x:Name="TimerLabel"
               Grid.Row="2"
               Text="30"
               FontSize="52"
               FontAttributes="Bold"
               TextColor="#00E5FF"
               HorizontalOptions="Center"
               Margin="0,0,0,24" />

        <!-- Cancel / Next -->
        <Grid Grid.Row="3" ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#1A1A2E"
                    TextColor="#555566"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="2"
                    Text="Next →"
                    BackgroundColor="#00E5FF"
                    TextColor="#0A0A12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnNextClicked" />
        </Grid>

    </Grid>

</ContentPage>
