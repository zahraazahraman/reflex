<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.WelcomePage"
             BackgroundColor="#0A0A12"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto" Padding="40,60,40,40">

        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="16">

            <Label Text="Reflex"
                   FontSize="56"
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"
                   HorizontalOptions="Center" />

            <Label Text="The app that sees your cognitive state before you do."
                   FontSize="15"
                   TextColor="#888899"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,32" />

            <!-- Last session card — hidden until a session exists -->
            <Frame x:Name="LastSessionFrame"
                   IsVisible="False"
                   BackgroundColor="#0D0D1A"
                   BorderColor="#1A1A2E"
                   CornerRadius="12"
                   Padding="20,14"
                   Margin="0,0,0,16">
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="LastScoreLabel"
                           Text="Last score: --"
                           FontSize="14"
                           TextColor="#888899"
                           HorizontalOptions="Center" />
                    <Label x:Name="LastTimeLabel"
                           Text=""
                           FontSize="12"
                           TextColor="#444455"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Start"
                    BackgroundColor="#00E5FF"
                    TextColor="#0A0A12"
                    FontAttributes="Bold"
                    FontSize="18"
                    HeightRequest="56"
                    CornerRadius="12"
                    Clicked="OnStartClicked" />

        </VerticalStackLayout>

        <Label Grid.Row="1"
               Text="5 tests · 3 minutes · All on-device"
               FontSize="12"
               TextColor="#444455"
               HorizontalOptions="Center" />

    </Grid>

</ContentPage>
