<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.AimPage"
             BackgroundColor="#0A0A12"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="40,32,40,0" Spacing="4">
            <Label Text="Test 3 of 5  ·  Aim"
                   FontSize="12"
                   TextColor="#444455"
                   HorizontalOptions="Center" />
            <Label x:Name="TargetLabel"
                   Text="Get ready…"
                   FontSize="16"
                   TextColor="#555566"
                   HorizontalOptions="Center"
                   Margin="0,6,0,0" />
            <!-- Per-target countdown bar -->
            <ProgressBar x:Name="TimeBar"
                         Progress="1"
                         ProgressColor="#00E5FF"
                         BackgroundColor="#1A1A2E"
                         HeightRequest="3"
                         Margin="0,8,0,0" />
        </VerticalStackLayout>

        <!-- Target area: visual circle + transparent full-area tap catcher -->
        <AbsoluteLayout x:Name="TargetArea" Grid.Row="1">

            <!-- Visual circle (position set in code-behind) -->
            <BoxView x:Name="AimCircle"
                     IsVisible="False"
                     Color="#00E5FF"
                     CornerRadius="999" />

            <!-- Transparent overlay — captures every tap in the area -->
            <BoxView Color="Transparent"
                     AbsoluteLayout.LayoutBounds="0,0,1,1"
                     AbsoluteLayout.LayoutFlags="All"
                     InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAreaTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

        </AbsoluteLayout>

        <!-- Cancel / Skip -->
        <Grid Grid.Row="2" Padding="40,0,40,40" ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#1A1A2E"
                    TextColor="#555566"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="2"
                    Text="Skip →"
                    BackgroundColor="#1A1A2E"
                    TextColor="#333355"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnSkipClicked" />
        </Grid>

    </Grid>

</ContentPage>
