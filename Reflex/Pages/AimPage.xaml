<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reflex.Pages.AimPage"
             BackgroundColor="#0A0A12"
             Shell.NavBarIsVisible="False">

    <Grid Padding="40" RowDefinitions="Auto,*,Auto">

        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Test 3 of 5  ·  Aim"
                   FontSize="12"
                   TextColor="#444455"
                   HorizontalOptions="Center" />
            <Label Text="Tap the center of each circle."
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"
                   HorizontalOptions="Center"
                   Margin="0,8,0,0" />
            <Label Text="Circles decrease in size. You have 3 seconds each."
                   FontSize="13"
                   TextColor="#888899"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Frame Grid.Row="1"
               BackgroundColor="#0D0D1A"
               BorderColor="#1A1A2E"
               CornerRadius="16"
               Margin="0,24">
            <VerticalStackLayout VerticalOptions="Center" Spacing="12">
                <Ellipse Fill="#1A3A4A"
                         WidthRequest="80"
                         HeightRequest="80"
                         HorizontalOptions="Center" />
                <Label Text="Target 0 / 20"
                       FontSize="12"
                       TextColor="#333355"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2" ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#1A1A2E"
                    TextColor="#555566"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="2"
                    Text="Next →"
                    BackgroundColor="#00E5FF"
                    TextColor="#0A0A12"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="10"
                    Clicked="OnNextClicked" />
        </Grid>

    </Grid>

</ContentPage>
